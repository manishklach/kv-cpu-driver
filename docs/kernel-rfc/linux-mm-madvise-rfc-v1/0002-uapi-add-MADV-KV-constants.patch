diff --git a/include/uapi/asm-generic/mman-common.h b/include/uapi/asm-generic/mman-common.h
index 1ea2c4c33b86..eeeeeeeeeeee 100644
--- a/include/uapi/asm-generic/mman-common.h
+++ b/include/uapi/asm-generic/mman-common.h
@@ -79,6 +79,12 @@
 #define MADV_GUARD_INSTALL 102		/* fatal signal on access to range */
 #define MADV_GUARD_REMOVE  103		/* unguard range */

+#define MADV_KV_HOT        104		/* KV blocks are hot; protect from eviction */
+#define MADV_KV_EVICT      105		/* KV blocks not needed; migrate to lower tier */
+#define MADV_KV_PREFETCH   106		/* hint decode step + lookahead to KV device
+					 * len encodes: high32 = lookahead_window W,
+					 *              low32  = current decode step t */
+
 /* compatibility flags */
 #define MAP_FILE	0

